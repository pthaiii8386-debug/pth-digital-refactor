# PTH DIGITAL Backend Configuration

# JWT Secret for authentication (required)
JWT_SECRET=your-secure-jwt-secret-here

# Server Port (optional, defaults to 3000)
PORT=3000

# TinOTP Integration (optional)
TINOTP_BASE_URL=https://tinotp.site/api
TINOTP_API_KEY=your-tinotp-api-key-here

# Environment (development/production)
NODE_ENV=production